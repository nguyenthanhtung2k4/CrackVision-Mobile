# ============================================================
# CrackVision Mobile — .gitignore
# Project: FastAPI backend + Flutter frontend + AI model
# ============================================================

# ============================================================
# SECRETS & ENVIRONMENT
# ============================================================
.env
.env.local
.env.production
*.env
!.env.example

# ============================================================
# PYTHON / BACKEND
# ============================================================
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd

# Virtual environments
.venv/
venv/
env/
ENV/
.python-version

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
.eggs/

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/

# Type checking
.mypy_cache/
.dmypy.json

# Jupyter Notebook checkpoints
.ipynb_checkpoints/
*.ipynb_checkpoints

# Alembic (giữ migrations, bỏ cache)
backend/alembic/__pycache__/

# Uploads (ảnh user upload — không commit lên git)
backend/uploads/
uploads/

# SQLite dev database
*.db
*.sqlite
*.sqlite3

# ============================================================
# AI MODEL
# ============================================================
# Model nặng — lưu riêng (Google Drive, HuggingFace, etc.)
*.keras
*.h5
*.pb
*.tflite
*.onnx
*.pt
*.pth
*.bin

# Giữ lại convert script và inference notebook
!AI_model/convert_tflite.py
!AI_model/inference.ipynb

# TensorFlow logs
logs/
tf_logs/
tensorboard_logs/

# ============================================================
# FLUTTER / DART
# ============================================================
# Build output
mobile/.dart_tool/
mobile/build/
mobile/.flutter-plugins
mobile/.flutter-plugins-dependencies

# Generated files
mobile/**/*.g.dart
mobile/**/*.freezed.dart
mobile/**/*.gr.dart

# iOS
mobile/ios/Pods/
mobile/ios/.symlinks/
mobile/ios/Flutter/Flutter.framework
mobile/ios/Flutter/Flutter.podspec
mobile/ios/Runner.xcworkspace/xcshareddata/
mobile/ios/Runner/GeneratedPluginRegistrant.*

# Android
mobile/android/.gradle/
mobile/android/local.properties
mobile/android/app/release/
mobile/android/key.properties
mobile/android/*.keystore
mobile/android/*.jks

# macOS
mobile/macos/Pods/
mobile/macos/Flutter/GeneratedPluginRegistrant.swift

# Web
mobile/web/

# Hive local database files (dữ liệu local user)
mobile/**/*.hive
mobile/**/*.lock

# Coverage
mobile/coverage/

# ============================================================
# IDEs & EDITORS
# ============================================================
# VS Code
.vscode/
!.vscode/extensions.json
!.vscode/settings.json

# JetBrains (IntelliJ, Android Studio, PyCharm)
.idea/
*.iml
*.iws
*.ipr
.idea_modules/

# Vim/Emacs
*.swp
*.swo
*~
.#*

# ============================================================
# OS FILES
# ============================================================
# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Linux
*~

# ============================================================
# LOGS
# ============================================================
*.log
*.log.*
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ============================================================
# NODE (Figma MCP tooling)
# ============================================================
node_modules/
npm-debug.log
package-lock.json
yarn.lock

# ============================================================
# DOCKER (nếu dùng sau này)
# ============================================================
# Giữ docker-compose.yml nhưng bỏ data volumes
docker-data/
postgres-data/

# ============================================================
# RELEASE / APK (build output)
# ============================================================
*.apk
*.aab
*.ipa
mobile/android/app/build/outputs/

# ============================================================
# TEMP & MISC
# ============================================================
tmp/
temp/
.tmp/
*.tmp
*.bak
*.orig
*.rej


docs/
.claude/