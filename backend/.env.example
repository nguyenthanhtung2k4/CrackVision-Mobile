# ============================================================
# CrackVision Backend — Environment Variables
# Copy file này thành .env và điền giá trị thật
# KHÔNG commit file .env lên git
# ============================================================

# --- Database ---
# PostgreSQL:
# DATABASE_URL=postgresql://postgres:password@localhost:5432/crackvision
# SQLite (dev nhanh, không cần cài DB):
# DATABASE_URL=sqlite:///./crackvision_dev.db
# MySQL:
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/crackvision

# --- JWT ---
JWT_SECRET_KEY=your-super-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- App ---
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# --- AI Model ---
MODEL_PATH=../AI_model/mobilenetv2_crack_final.keras
MODEL_THRESHOLD=0.5

# --- File Upload ---
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10

# --- CORS ---
ALLOWED_ORIGINS=http://localhost:3000,http://10.0.2.2:8000
